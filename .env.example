# ═══════════════════════════════════════════════════════════════════════════
# Dev igual à produção: `npm run dev` usa modo production → carrega .env.production
# e .env.production.local (recomendado: copie os VITE_* da Vercel para .env.production.local).
# Para só .env.development: npm run dev:local
# ═══════════════════════════════════════════════════════════════════════════
#
# Utilizadores finais NÃO precisam de .env — só quem publica a app.
#
# Opção A — Oficial: preencha apiKey + appId em src/config/planizePublicFirebase.ts
#   (Firebase Console → Definições → app Web do projeto planize-520c3).
#
# Opção B — Vercel: defina as variáveis abaixo (sobrepõem o ficheiro).
#
# Firebase: Authentication → Email → "Email link"; Firestore; deploy das regras.
# ═══════════════════════════════════════════════════════════════════════════

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=planize-520c3.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=planize-520c3
VITE_FIREBASE_APP_ID=
# URL exata do site (com / no fim) — deve constar em Auth → Authorized domains
VITE_APP_URL=https://seu-dominio.vercel.app/

# Opcional: email ao titular quando um convidado pede acesso (Vercel → env)
# RESEND_API_KEY=
# RESEND_FROM=Planize <noreply@seudominio.com>
